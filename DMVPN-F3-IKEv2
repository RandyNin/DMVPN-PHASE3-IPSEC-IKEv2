### R-SITE-A-SPOKE ###

ena
conf t
no ip domain-lookup
hostname R-SITE-A-SPOKE

int gig0/1
ip add 20.21.22.1 255.255.255.252
no shut
exit

int gig0/0
ip add 192.168.10.1 255.255.255.0
no shut
exit

ip route 0.0.0.0 0.0.0.0 20.21.22.2

ip dhcp excluded-address 192.168.10.1 192.168.10.9
ip dhcp pool SITE-A
network 192.168.10.0 255.255.255.0
default-router 192.168.10.1
dns-server 8.8.8.8
exit

crypto ikev2 proposal IKEv2_PROP
encryption aes-cbc-256
integrity sha256
group 14
exit

crypto ikev2 policy IKEv2_POL
proposal IKEv2_PROP
exit

crypto ikev2 keyring IKEv2_KEYRING
peer ANY
address 0.0.0.0 0.0.0.0
pre-shared-key randy123
exit

crypto ikev2 profile IKEv2_PROF
match identity remote address 0.0.0.0
authentication remote pre-share
authentication local pre-share
keyring local IKEv2_KEYRING
lifetime 86400
exit

crypto ipsec transform-set TRANF_SET esp-aes 256 esp-sha256-hmac
mode transport
exit

crypto ipsec profile IKEv2_VTI_PROF
set transform-set TRANF_SET
set ikev2-profile IKEv2_PROF
set pfs group14
exit

interface Tunnel0
ip address 172.16.0.2 255.255.255.0
tunnel source GigabitEthernet0/1
tunnel mode gre multipoint
ip nhrp network-id 1
ip nhrp authentication randy321
ip nhrp nhs 172.16.0.1
ip nhrp map 172.16.0.1 30.31.32.1
ip nhrp map multicast 30.31.32.1
ip nhrp shortcut
ip ospf network point-to-multipoint
tunnel protection ipsec profile IKEv2_VTI_PROF
exit

router ospf 10
router-id 2.2.2.2
network 192.168.10.0 0.0.0.255 area 0
network 172.16.0.0 0.0.0.255 area 0
exit

do wr

